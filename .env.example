# Athena Backend Environment Variables
APP_NAME=Athena
APP_VERSION=0.1.0
ENV=development

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://athena:athena@localhost:5432/athena

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=athena
MINIO_SECRET_KEY=athena_secret
MINIO_BUCKET=athena

# LiteLLM (AI Gateway)
LITELLM_API_KEY=
LITELLM_BASE_URL=http://localhost:4000
